{
    "version": "0.10.6.2",
    "description": "Bullshit-free web browser, based on Chromium. Follows imput's ethics and norms.",
    "homepage": "https://helium.imput.net/",
    "license": {
        "identifier": " GPL-3.0-only",
        "url": "https://github.com/imputnet/helium-chromium/blob/main/LICENSE"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/imputnet/helium-windows/releases/download/0.10.6.2/helium_0.10.6.2_x64-windows.zip",
            "hash": "958ca13698c1ef0e2ea5f3724ce344da99943a33d061d9c7b153bf7f19d6a3ed",
            "extract_dir": "helium_0.10.6.2_x64-windows"
        },
        "arm64": {
            "url": "https://github.com/imputnet/helium-windows/releases/download/0.10.6.2/helium_0.10.6.2_arm64-windows.zip",
            "hash": "c99e90eb72f5ac640933f8dd8539729e32a16a4e7cbf3acd8f740d60f25907ae",
            "extract_dir": "helium_0.10.6.2_arm64-windows"
        }
    },
    "bin": [
        [
            "chrome.exe",
            "helium",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "shortcuts": [
        [
            "chrome.exe",
            "Helium",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "post_install": [
        "if (!(Test-Path \"$dir\\User Data\\*\") -and (Test-Path \"$env:LocalAppData\\imput\\Helium\\User Data\")) {",
        "    info '[Portable Mode]: Copying user data...'",
        "    Copy-Item \"$env:LocalAppData\\imput\\Helium\\User Data\\*\" \"$dir\\User Data\" -Recurse",
        "}"
    ],
    "env_set": {
        "CHROME_EXECUTABLE": "$dir\\chrome.exe"
    },
    "persist": "User Data",
    "checkver": {
        "github": "https://github.com/imputnet/helium-windows/"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/imputnet/helium-windows/releases/download/$version/helium_$version_x64-windows.zip",
                "extract_dir": "helium_$version_x64-windows"
            },
            "arm64": {
                "url": "https://github.com/imputnet/helium-windows/releases/download/$version/helium_$version_arm64-windows.zip",
                "extract_dir": "helium_$version_arm64-windows"
            }
        }
    }
}
